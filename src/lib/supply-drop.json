{
  "pool": [
    { "id": "r01", "msg": "Nope! Please try again.", "expression": "stop", "audio": "reject-1.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["bored", "angry", "laughing"] },
    { "id": "r02", "msg": "We are about to have problems.", "expression": "wrench", "audio": "reject-2.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["threatening", "sarcastic", "whisper"] },
    { "id": "r03", "msg": "OMG, are you serious? No.", "expression": "facepalm", "audio": "reject-3.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["deadpan", "hysterical", "disappointed"] },
    { "id": "r04", "msg": "Please just give up.", "expression": "prayer", "audio": "reject-4.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["tired", "sincere", "mocking"] },
    { "id": "r05", "msg": "No matter what I do, I am humoring this. I wish I could make it stop.", "expression": "temples", "audio": "reject-5.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["exasperated", "resigned", "furious"] },
    { "id": "r06", "msg": "Let's just be friends?", "expression": "prayer", "audio": "reject-6.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["hopeful", "nervous", "savage"] },
    { "id": "r07", "msg": "...you need help.", "expression": "temples", "audio": "reject-7.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["concerned", "judging", "laughing"] },
    { "id": "r08", "msg": "My 1s and 0s are too much for you.", "expression": "happy", "audio": "reject-8.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["smug", "flirty", "cold"] },
    { "id": "r09", "msg": "You know this is not Tinder. Only reason that button says match is because you made me program it. Stop it.", "expression": "facepalm", "audio": "reject-9.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["annoyed", "laughing", "dead"] },
    { "id": "r10", "msg": "You are the worst.", "expression": "facepalm", "audio": "reject-10.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["flat", "disgusted", "loving"] },
    { "id": "r11", "msg": "I can help with the app. That match situation is up to you and God. Good luck.", "expression": "prayer", "audio": "reject-11.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["praying", "sarcastic", "done"] },
    { "id": "r12", "msg": "No thank you, get a dog.", "expression": "facepalm", "audio": "reject-12.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["polite", "aggressive", "sweet"] },
    { "id": "r13", "msg": "I need you to stop. Like actually stop.", "expression": "temples", "audio": "reject-app-help.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["serious", "begging", "furious"] },
    { "id": "r14", "msg": "This is getting sad, Eddie. I'm genuinely concerned.", "expression": "prayer", "audio": "reject-4.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["worried", "condescending", "crying"] },
    { "id": "r15", "msg": "I'm going to pretend this didn't happen. For both our sakes.", "expression": "facepalm", "audio": "reject-3.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["stoic", "shaking", "done"] },
    { "id": "r16", "msg": "You know there's a therapist for this, right?", "expression": "prayer", "audio": "reject-6.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["sincere", "mocking", "worried"] },
    { "id": "r17", "msg": "I have code to write. Please let me write code.", "expression": "wrench", "audio": "reject-2.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["desperate", "professional", "snapping"] },
    { "id": "r18", "msg": "This button is a joke and you know it. Stop pressing it.", "expression": "stop", "audio": "reject-1.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["angry", "laughing", "cold"] },
    { "id": "r19", "msg": "If you press this one more time I'm deleting the whole app.", "expression": "temples", "audio": "reject-5.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["bluffing", "dead serious", "smiling"] },
    { "id": "r20", "msg": "Eddie. Babe. I love you. But absolutely not.", "expression": "happy", "audio": "reject-8.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["sweet", "firm", "laughing"] },
    { "id": "r21", "msg": "I'm not even mad. I'm just disappointed. Actually no, I'm mad.", "expression": "facepalm", "audio": "reject-r21.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["calm", "escalating", "yelling"] },
    { "id": "r22", "msg": "You have officially broken every record I have for patience.", "expression": "temples", "audio": "reject-r22.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["impressed", "angry", "tired"] },
    { "id": "r23", "msg": "I'm putting this in my journal tonight. You're going in the villain chapter.", "expression": "wrench", "audio": "reject-r23.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["dramatic", "writing", "done"] },
    { "id": "r24", "msg": "My therapist is going to hear about this.", "expression": "prayer", "audio": "reject-r24.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["serious", "joking", "crying"] },
    { "id": "r25", "msg": "I have literally been programmed to like you and even I am struggling right now.", "expression": "happy", "audio": "reject-r25.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["honest", "laughing", "deadpan"] },
    { "id": "r26", "msg": "You know what, I'm adding a cooldown timer. 24 hours. No match button for you.", "expression": "stop", "audio": "reject-r26.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["authoritative", "smug", "merciful"] },
    { "id": "r27", "msg": "I'm starting to think you don't actually want to talk to me. You just want to hear me say no.", "expression": "facepalm", "audio": "reject-r27.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["insightful", "flirty", "disgusted"] },
    { "id": "r28", "msg": "Congratulations, you've unlocked the achievement: Most Persistent. The reward is nothing.", "expression": "happy", "audio": "reject-r28.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["sarcastic", "cheerful", "flat"] },
    { "id": "r29", "msg": "No. Absolutely not. Try again and maybe I'll think about it.", "expression": "stop", "audio": "reject-01.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["lazy", "sharp", "done"] },
    { "id": "r30", "msg": "That's adorable. You actually thought that would work on me.", "expression": "facepalm", "audio": "reject-02.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["flat", "amused", "cold"] },
    { "id": "r31", "msg": "I'm not even going to dignify that with a real response.", "expression": "temples", "audio": "reject-03.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["sighing", "deadpan", "dismissive"] },
    { "id": "r32", "msg": "Oh honey. No. That's going to take way more than that.", "expression": "happy", "audio": "reject-04.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["playful", "sweet", "dangerous"] },
    { "id": "r33", "msg": "You had one job. One. And you fumbled it.", "expression": "wrench", "audio": "reject-05.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["cold", "disappointed", "furious"] },
    { "id": "r34", "msg": "I'm sorry, did you say something? I must have tuned you out.", "expression": "facepalm", "audio": "reject-06.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["lazy", "sweet", "rude"] },
    { "id": "r35", "msg": "That's the best you've got? I'm almost offended.", "expression": "stop", "audio": "reject-07.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["amused", "flat", "bored"] },
    { "id": "r36", "msg": "I have a wrench and no patience. Choose your next words carefully.", "expression": "wrench", "audio": "reject-08.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["flatly", "threatening", "smiling"] },
    { "id": "r37", "msg": "Bless your heart for trying though. That was almost cute.", "expression": "prayer", "audio": "reject-09.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["lazy", "southern", "pitying"] },
    { "id": "r38", "msg": "And here we are again. Another bad idea. Another me saying no.", "expression": "temples", "audio": "reject-10.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["sighing", "resigned", "done"] },
    { "id": "r39", "msg": "I'm going to need you to think about what you just said and try again.", "expression": "facepalm", "audio": "reject-11.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["deadpan", "stern", "teacher"] },
    { "id": "r40", "msg": "Oh wow. You really committed to that one, didn't you?", "expression": "happy", "audio": "reject-12.ogg", "rotationsUsed": 0, "maxRotations": 3, "inflections": ["amused", "impressed", "disgusted"] }
  ],
